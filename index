<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Ganoe Saloon — Custom Bar Proposal | Rustic Expressions</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,800;1,400;1,600&family=EB+Garamond:wght@400;500&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --caoba: #4F2014;
    --caoba-light: #7a3520;
    --bone: #EBE6DB;
    --bone-dark: #d9d1c0;
    --wood: #B58E66;
    --autum: #965A32;
    --cloudy: #959F94;
    --ink: #1a1108;
    --parchment: #F7F2E8;
    --gold: #C9A84C;
    --gold-light: #e0c47a;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'EB Garamond', Georgia, serif;
    background: var(--parchment);
    color: var(--ink);
    line-height: 1.7;
    font-size: 17px;
  }

  /* ─── HERO ─────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    overflow: hidden;
    background: var(--ink);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('PLACEHOLDER_IMG2');
    background-size: cover;
    background-position: center 30%;
    opacity: 0.38;
  }

  .hero-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 20%, rgba(26,17,8,0.80) 100%);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding: 60px 40px;
    max-width: 800px;
  }

  .brand-lockup {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 48px;
  }

  .brand-line {
    height: 1px;
    width: 60px;
    background: var(--gold);
    flex-shrink: 0;
  }

  .brand-name {
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.28em;
    color: var(--gold);
    text-transform: uppercase;
    white-space: nowrap;
  }

  .hero-eyebrow {
    font-family: 'Montserrat', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.30em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 24px;
  }

  .hero-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(48px, 8vw, 90px);
    font-weight: 800;
    font-style: italic;
    line-height: 1.0;
    color: #fff;
    margin-bottom: 6px;
    letter-spacing: -0.01em;
  }

  .hero-title span {
    color: var(--gold);
    font-style: normal;
  }

  .hero-subtitle {
    font-family: 'Playfair Display', serif;
    font-size: clamp(16px, 2.5vw, 22px);
    font-weight: 400;
    color: var(--bone-dark);
    margin-bottom: 40px;
    letter-spacing: 0.04em;
  }

  .hero-divider {
    width: 80px;
    height: 2px;
    background: var(--gold);
    margin: 0 auto 40px;
  }

  .hero-meta {
    display: flex;
    gap: 40px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-meta-item {
    text-align: center;
  }

  .hero-meta-label {
    font-family: 'Montserrat', sans-serif;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    color: var(--gold);
    display: block;
    margin-bottom: 4px;
  }

  .hero-meta-value {
    font-family: 'Playfair Display', serif;
    font-size: 16px;
    color: #fff;
    font-weight: 400;
  }

  .scroll-hint {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    color: var(--gold);
    font-family: 'Montserrat', sans-serif;
    font-size: 9px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    animation: bounce 2s infinite;
  }

  .scroll-hint::after {
    content: '';
    display: block;
    width: 1px;
    height: 40px;
    background: var(--gold);
    opacity: 0.6;
  }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(6px); }
  }

  /* ─── SECTIONS ──────────────────────────────────────── */
  .section {
    padding: 100px 40px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-dark {
    background: var(--caoba);
    color: var(--bone);
    max-width: 100%;
    padding: 100px 40px;
  }

  .section-dark-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-label {
    font-family: 'Montserrat', sans-serif;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--gold);
    display: block;
    margin-bottom: 18px;
  }

  .section-dark .section-label {
    color: var(--gold-light);
  }

  .section-heading {
    font-family: 'Playfair Display', serif;
    font-size: clamp(32px, 5vw, 54px);
    font-weight: 700;
    line-height: 1.15;
    color: var(--caoba);
    margin-bottom: 28px;
    letter-spacing: -0.01em;
  }

  .section-dark .section-heading {
    color: var(--bone);
  }

  .section-heading em {
    font-style: italic;
    color: var(--autum);
  }

  .section-dark .section-heading em {
    color: var(--gold-light);
  }

  .lead {
    font-size: 20px;
    line-height: 1.75;
    color: #4a3520;
    max-width: 700px;
    margin-bottom: 48px;
  }

  .section-dark .lead {
    color: var(--bone-dark);
  }

  /* ─── VISION RENDER ─────────────────────────────────── */
  .vision-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
    margin-top: 60px;
  }

  .vision-image {
    width: 100%;
    border-radius: 4px;
    display: block;
    box-shadow: 0 24px 60px rgba(26,17,8,0.30);
  }

  .vision-caption {
    font-family: 'Montserrat', sans-serif;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cloudy);
    margin-top: 14px;
    display: block;
    text-align: center;
  }

  .vision-text {
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding-top: 10px;
  }

  .vision-text p {
    font-size: 17px;
    line-height: 1.8;
    color: var(--bone-dark);
  }

  .vision-attrs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 8px;
  }

  .vision-attr {
    border-left: 2px solid var(--gold);
    padding-left: 14px;
  }

  .vision-attr-label {
    font-family: 'Montserrat', sans-serif;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold-light);
    display: block;
    margin-bottom: 4px;
  }

  .vision-attr-value {
    font-family: 'Playfair Display', serif;
    font-size: 16px;
    color: var(--bone);
  }

  /* ─── FLOOR PLAN ─────────────────────────────────────── */
  .floorplan-wrap {
    background: #fff;
    border: 1px solid var(--bone-dark);
    border-radius: 6px;
    padding: 32px;
    margin-top: 50px;
    box-shadow: 0 8px 32px rgba(26,17,8,0.10);
  }

  .floorplan-wrap img {
    width: 100%;
    display: block;
    border-radius: 4px;
  }

  .floorplan-note {
    font-family: 'Montserrat', sans-serif;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--cloudy);
    text-align: center;
    margin-top: 16px;
  }

  /* ─── SPECS TABLE ─────────────────────────────────────── */
  .specs-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    margin-top: 56px;
  }

  .spec-card {
    background: #fff;
    border: 1px solid var(--bone-dark);
    border-top: 4px solid var(--caoba);
    padding: 32px 28px;
    border-radius: 4px;
    position: relative;
  }

  .spec-number {
    position: absolute;
    top: -18px;
    left: 28px;
    background: var(--caoba);
    color: var(--gold);
    font-family: 'Montserrat', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    padding: 4px 12px;
    border-radius: 2px;
  }

  .spec-name {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--caoba);
    margin-bottom: 6px;
    margin-top: 8px;
  }

  .spec-dims {
    font-family: 'Montserrat', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.14em;
    color: var(--autum);
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .spec-details {
    font-size: 15px;
    line-height: 1.7;
    color: #4a3520;
    margin-bottom: 20px;
  }

  .spec-price {
    font-family: 'Playfair Display', serif;
    font-size: 28px;
    font-weight: 800;
    color: var(--caoba);
    letter-spacing: -0.01em;
  }

  .spec-price-label {
    font-family: 'Montserrat', sans-serif;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--cloudy);
    display: block;
    margin-bottom: 4px;
  }

  /* ─── STOOLS SECTION ─────────────────────────────────── */
  .stools-wrap {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 60px;
    align-items: center;
    margin-top: 56px;
  }

  .stools-image-wrap {
    position: relative;
  }

  .stools-image {
    width: 100%;
    border-radius: 4px;
    display: block;
    box-shadow: 0 20px 56px rgba(26,17,8,0.28);
  }

  .stools-badge {
    position: absolute;
    top: 20px;
    left: 20px;
    background: var(--caoba);
    color: var(--gold);
    font-family: 'Montserrat', sans-serif;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 2px;
  }

  .stools-text h3 {
    font-family: 'Playfair Display', serif;
    font-size: 32px;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 16px;
    line-height: 1.2;
  }

  .stools-text p {
    font-size: 17px;
    line-height: 1.8;
    color: #4a3520;
    margin-bottom: 20px;
  }

  .stools-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .stools-features li {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 15px;
    color: #4a3520;
  }

  .stools-features li::before {
    content: '';
    display: block;
    width: 20px;
    height: 2px;
    background: var(--gold);
    flex-shrink: 0;
  }

  /* ─── PRICING SUMMARY ────────────────────────────────── */
  .pricing-block {
    background: var(--ink);
    border-radius: 6px;
    padding: 64px 60px;
    margin-top: 56px;
    position: relative;
    overflow: hidden;
  }

  .pricing-block::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--gold), var(--autum), var(--gold));
  }

  .pricing-block-title {
    font-family: 'Playfair Display', serif;
    font-size: 14px;
    font-weight: 400;
    font-style: italic;
    color: var(--bone-dark);
    margin-bottom: 40px;
    letter-spacing: 0.04em;
  }

  .pricing-lines {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .pricing-line {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 18px 0;
    border-bottom: 1px solid rgba(235,230,219,0.12);
  }

  .pricing-line:last-child {
    border-bottom: none;
  }

  .pricing-line-name {
    font-family: 'EB Garamond', serif;
    font-size: 18px;
    color: var(--bone);
  }

  .pricing-line-sub {
    font-family: 'Montserrat', sans-serif;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.14em;
    color: var(--cloudy);
    display: block;
    margin-top: 3px;
  }

  .pricing-line-amount {
    font-family: 'Playfair Display', serif;
    font-size: 20px;
    font-weight: 600;
    color: var(--bone);
    white-space: nowrap;
    margin-left: 24px;
  }

  .pricing-divider {
    height: 1px;
    background: rgba(201,168,76,0.4);
    margin: 8px 0;
  }

  .pricing-total-line {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 28px 0 0;
  }

  .pricing-total-label {
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .pricing-total-amount {
    font-family: 'Playfair Display', serif;
    font-size: 42px;
    font-weight: 800;
    color: var(--gold);
    letter-spacing: -0.02em;
  }

  .pricing-note {
    font-family: 'Montserrat', sans-serif;
    font-size: 10px;
    letter-spacing: 0.12em;
    color: var(--cloudy);
    margin-top: 16px;
    font-style: italic;
  }

  /* ─── CRAFTSMANSHIP PROMISE ──────────────────────────── */
  .promise-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-top: 56px;
  }

  .promise-card {
    padding: 32px 28px;
    border: 1px solid rgba(201,168,76,0.3);
    border-radius: 4px;
    background: rgba(201,168,76,0.04);
  }

  .promise-icon {
    font-size: 28px;
    margin-bottom: 16px;
    display: block;
  }

  .promise-title {
    font-family: 'Playfair Display', serif;
    font-size: 18px;
    font-weight: 700;
    color: var(--bone);
    margin-bottom: 10px;
  }

  .promise-text {
    font-size: 14px;
    line-height: 1.75;
    color: var(--bone-dark);
    opacity: 0.85;
  }

  /* ─── REVIEW & APPROVE ───────────────────────────────── */
  .approve-wrap {
    max-width: 680px;
    margin: 0 auto;
    text-align: center;
  }

  .approve-wrap .section-heading {
    font-size: clamp(32px, 4vw, 46px);
  }

  .approve-wrap .lead {
    margin-left: auto;
    margin-right: auto;
    text-align: center;
  }

  .signature-block {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: center;
    margin-bottom: 48px;
  }

  .signature-line-label {
    font-family: 'Montserrat', sans-serif;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--cloudy);
  }

  .signature-box {
    width: 320px;
    border-bottom: 1.5px solid var(--bone-dark);
    padding: 18px 0 6px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .sig-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 24px;
  }

  .sig-field {
    flex: 1;
    text-align: left;
  }

  .sig-field-label {
    font-family: 'Montserrat', sans-serif;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cloudy);
    display: block;
    margin-bottom: 6px;
  }

  .sig-line {
    border-bottom: 1px solid var(--bone-dark);
    padding-bottom: 6px;
    min-width: 120px;
    height: 28px;
  }

  .approve-btn-group {
    display: flex;
    gap: 20px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 8px;
  }

  .btn-primary {
    display: inline-block;
    background: var(--caoba);
    color: var(--gold);
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    padding: 18px 44px;
    border: none;
    border-radius: 3px;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.2s, transform 0.1s;
    box-shadow: 0 8px 24px rgba(79,32,20,0.25);
  }

  .btn-primary:hover {
    background: var(--caoba-light);
    transform: translateY(-2px);
  }

  .btn-secondary {
    display: inline-block;
    background: transparent;
    color: var(--caoba);
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    padding: 18px 44px;
    border: 1.5px solid var(--caoba);
    border-radius: 3px;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-secondary:hover {
    background: var(--caoba);
    color: var(--gold);
  }

  /* ─── CONTACT STRIP ──────────────────────────────────── */
  .contact-strip {
    background: var(--caoba);
    padding: 48px 40px;
    text-align: center;
    border-top: 4px solid var(--gold);
  }

  .contact-strip-label {
    font-family: 'Montserrat', sans-serif;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.30em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
    display: block;
  }

  .contact-strip-items {
    display: flex;
    gap: 48px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .contact-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .contact-item-label {
    font-family: 'Montserrat', sans-serif;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(201,168,76,0.7);
  }

  .contact-item-value {
    font-family: 'EB Garamond', serif;
    font-size: 17px;
    color: var(--bone);
  }

  .contact-item-value a {
    color: var(--bone);
    text-decoration: none;
  }

  /* ─── FOOTER ─────────────────────────────────────────── */
  .footer {
    background: var(--ink);
    padding: 32px 40px;
    text-align: center;
  }

  .footer-brand {
    font-family: 'Montserrat', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 12px;
    display: block;
  }

  .footer-text {
    font-family: 'EB Garamond', serif;
    font-size: 13px;
    color: var(--cloudy);
  }

  /* ─── DIVIDERS ───────────────────────────────────────── */
  .ornament {
    display: flex;
    align-items: center;
    gap: 20px;
    margin: 64px 0 48px;
  }

  .ornament-line {
    flex: 1;
    height: 1px;
    background: var(--bone-dark);
  }

  .ornament-mark {
    font-family: 'Playfair Display', serif;
    font-size: 20px;
    color: var(--gold);
  }

  /* ─── RESPONSIVE ─────────────────────────────────────── */
  @media (max-width: 768px) {
    .vision-block, .stools-wrap, .specs-grid, .promise-grid {
      grid-template-columns: 1fr;
    }
    .pricing-block { padding: 40px 28px; }
    .section { padding: 72px 24px; }
    .hero-meta { gap: 24px; }
    .vision-attrs { grid-template-columns: 1fr; }
    .sig-row { flex-direction: column; gap: 16px; }
    .approve-btn-group { flex-direction: column; align-items: center; }
    .btn-primary, .btn-secondary { width: 100%; max-width: 320px; text-align: center; }
    .pricing-total-amount { font-size: 32px; }
  }
</style>
</head>
<body>

<!-- ═══════════════════════════════ HERO ═══════════════════════════════ -->
<section class="hero">
  <div class="hero-bg" id="heroBg"></div>
  <div class="hero-vignette"></div>

  <div class="hero-content">
    <div class="brand-lockup">
      <div class="brand-line"></div>
      <span class="brand-name">Rustic Expressions Texas®</span>
      <div class="brand-line"></div>
    </div>

    <p class="hero-eyebrow">Custom Build Proposal · Est. 1989</p>
    <h1 class="hero-title">The Ganoe<br><span>Saloon</span></h1>
    <p class="hero-subtitle">A Western bar crafted entirely to your vision</p>
    <div class="hero-divider"></div>

    <div class="hero-meta">
      <div class="hero-meta-item">
        <span class="hero-meta-label">Client</span>
        <span class="hero-meta-value">Steve Ganoe</span>
      </div>
      <div class="hero-meta-item">
        <span class="hero-meta-label">Room</span>
        <span class="hero-meta-value">19′ × 21′</span>
